{
  "all": true,
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/test/**",
    "**/*.d.ts",
    "out/**",
    "dist/**",
    "esbuild.js"
  ],
  "reporter": [
    "lcov",
    "text",
    "html",
    "json-summary"
  ],
  "check-coverage": true,
  "lines": 90,
  "statements": 90,
  "functions": 90,
  "branches": 85
}

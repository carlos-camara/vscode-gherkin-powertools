{
  "name": "vscode-gherkin-beautifier",
  "displayName": "Gherkin Beautifier",
  "description": "Professional Gherkin (.feature) formatter and table aligner",
  "version": "1.4.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Formatters"
  ],
  "publisher": "carloscamara",
  "author": "Carlos Camara",
  "icon": "assets/logo.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/carloscamara/vscode-gherkin-beautifier"
  },
  "activationEvents": [
    "onLanguage:feature"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "feature",
        "extensions": [".feature"],
        "aliases": ["Feature", "gherkin"]
      }
    ],
    "configuration": {
      "title": "Gherkin Beautifier",
      "properties": {
        "gherkinBeautifier.indentation.steps": {
          "type": "number",
          "default": 4,
          "description": "Number of spaces to indent steps (Given, When, Then, And, But, Examples, *)."
        },
        "gherkinBeautifier.tables.alignToKeyword": {
          "type": "boolean",
          "default": true,
          "description": "If true, tables align dynamically to the start of the step text. If false, tables simply indent slightly more than the step keyword."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "^18.16.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "typescript": "^5.1.3",
    "@vscode/test-electron": "^2.3.2"
  }
}

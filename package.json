{
  "name": "vscode-gherkin-powertools",
  "displayName": "Gherkin PowerTools",
  "description": "Format, lint, and navigate Gherkin (.feature) files in VS Code. Includes dynamic table alignment, real-time syntax checking, and Python/Behave step definition tooling.",
  "version": "1.7.2",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Formatters",
    "Linters",
    "Snippets",
    "Testing",
    "Programming Languages"
  ],
  "keywords": [
    "gherkin",
    "cucumber",
    "behave",
    "specflow",
    "formatter",
    "linter",
    "python",
    "testing"
  ],
  "publisher": "carloscamara",
  "author": "Carlos Camara",
  "icon": "assets/logo.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/carlos-camara/vscode-gherkin-powertools"
  },
  "activationEvents": [
    "onLanguage:feature"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "feature",
        "extensions": [
          ".feature"
        ],
        "aliases": [
          "Feature",
          "gherkin"
        ]
      }
    ],
    "configuration": {
      "title": "Gherkin PowerTools",
      "properties": {
        "gherkinPowerTools.indentation.steps": {
          "type": "number",
          "default": 4,
          "description": "Number of spaces to indent steps."
        },
        "gherkinPowerTools.tables.alignToKeyword": {
          "type": "boolean",
          "default": true,
          "description": "If true, tables align dynamically to the start of the step text. If false, tables simply indent slightly more than the step keyword."
        },
        "gherkinPowerTools.tags.format": {
          "type": "string",
          "enum": [
            "wrap",
            "singleLine"
          ],
          "default": "wrap",
          "description": "How to format long lists of tags. 'wrap' splits them across multiple lines (max 80 chars), 'singleLine' keeps them all on one line."
        },
        "gherkinPowerTools.emptyLines.betweenScenarios": {
          "type": "number",
          "default": 1,
          "description": "Number of empty lines to enforce between Scenario/Rule/Background blocks."
        },
        "gherkinPowerTools.behave.stepGlobs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/steps/**/*.py",
            "**/features/steps/**/*.py"
          ],
          "description": "Glob patterns to locate Python/Behave step definition files."
        },
        "gherkinPowerTools.behave.ignoreGlobs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/node_modules/**",
            "**/.venv/**",
            "**/venv/**",
            "**/env/**"
          ],
          "description": "Glob patterns to ignore when locating Python/Behave step definition files."
        }
      }
    },
    "commands": [
      {
        "command": "gherkinPowerTools.format",
        "title": "Format Gherkin Document"
      },
      {
        "command": "gherkinPowerTools.showStatistics",
        "title": "Gherkin: Show Project Statistics"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "editorLangId == feature",
          "command": "gherkinPowerTools.format",
          "group": "1_modification"
        },
        {
          "when": "editorLangId == feature",
          "command": "gherkinPowerTools.showStatistics",
          "group": "1_modification"
        }
      ]
    },
    "snippets": [
      {
        "language": "feature",
        "path": "./snippets.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild -- --production",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "esbuild": "node esbuild.js",
    "esbuild-watch": "node esbuild.js --watch",
    "pretest": "npm run compile && npm run esbuild",
    "test": "vscode-test --label unitTests",
    "test:e2e": "vscode-test --label e2eTests",
    "coverage": "vscode-test --label unitTests --coverage --coverage-reporter=lcov --coverage-reporter=text --coverage-reporter=html --coverage-reporter=json-summary"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.1",
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.93.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "c8": "^11.0.0",
    "esbuild": "^0.28.1",
    "mocha": "^11.7.6",
    "mocha-junit-reporter": "^2.2.1",
    "mocha-multi-reporters": "^1.5.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^7.0.2"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  },
  "dependencies": {
    "@cucumber/gherkin": "^41.0.0",
    "@cucumber/messages": "^34.0.1"
  }
}
